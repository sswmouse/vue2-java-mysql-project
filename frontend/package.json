{
  "name": "vue2-java-mysql-frontend",
  "version": "1.0.0",
  "description": "Vue2 frontend for Java MySQL project",
  "private": true,
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "lint": "vue-cli-service lint",
    "test:e2e": "jest"
  },
  "dependencies": {
    "axios": "^0.27.2",
    "element-ui": "^2.15.12",
    "gsap": "^3.14.2",
    "vue": "^2.6.14",
    "vue-router": "^3.5.3",
    "vuedraggable": "^2.24.3",
    "vuex": "^3.6.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/puppeteer": "^5.4.7",
    "@vue/cli-plugin-babel": "~4.5.19",
    "@vue/cli-plugin-eslint": "~4.5.19",
    "@vue/cli-plugin-router": "~4.5.19",
    "@vue/cli-plugin-vuex": "~4.5.19",
    "@vue/cli-service": "~4.5.19",
    "babel-eslint": "^10.1.0",
    "eslint": "^6.8.0",
    "eslint-plugin-vue": "^6.2.2",
    "jest": "^30.3.0",
    "jest-puppeteer": "^11.0.0",
    "less": "^4.1.3",
    "less-loader": "^7.3.0",
    "puppeteer": "^24.40.0",
    "vue-template-compiler": "^2.6.14"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true,
      "browser": true,
      "es6": true
    },
    "extends": [
      "plugin:vue/essential",
      "eslint:recommended",
      "plugin:vue/recommended"
    ],
    "parserOptions": {
      "parser": "babel-eslint",
      "ecmaVersion": 2020,
      "sourceType": "module"
    },
    "rules": {
      "indent": [
        "error",
        4,
        {
          "SwitchCase": 1
        }
      ],
      "semi": [
        "error",
        "never"
      ],
      "quotes": [
        "error",
        "single"
      ],
      "comma-dangle": [
        "error",
        "never"
      ],
      "no-var": "error",
      "prefer-const": "error",
      "vue/html-indent": [
        "error",
        4
      ],
      "vue/max-attributes-per-line": [
        "error",
        {
          "singleline": 1,
          "multiline": 1
        }
      ],
      "vue/component-name-in-template-casing": [
        "error",
        "kebab-case"
      ],
      "vue/require-default-prop": "error",
      "vue/require-prop-types": "error"
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
