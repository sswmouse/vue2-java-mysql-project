{
  "name": "vue2-java-mysql-frontend",
  "version": "1.0.0",
  "description": "Vue2 frontend for Java MySQL project",
  "private": true,
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "lint": "vue-cli-service lint"
  },
  "dependencies": {
    "vue": "^2.6.14",
    "vue-router": "^3.5.3",
    "vuex": "^3.6.2",
    "axios": "^0.27.2",
    "element-ui": "^2.15.12"
  },
  "devDependencies": {
    "@vue/cli-service": "~4.5.19",
    "@vue/cli-plugin-babel": "~4.5.19",
    "@vue/cli-plugin-eslint": "~4.5.19",
    "@vue/cli-plugin-router": "~4.5.19",
    "@vue/cli-plugin-vuex": "~4.5.19",
    "babel-eslint": "^10.1.0",
    "eslint": "^6.8.0",
    "eslint-plugin-vue": "^6.2.2",
    "vue-template-compiler": "^2.6.14",
    "less": "^4.1.3",
    "less-loader": "^7.3.0"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true,
      "browser": true,
      "es6": true
    },
    "extends": [
      "plugin:vue/essential",
      "eslint:recommended",
      "plugin:vue/recommended"
    ],
    "parserOptions": {
      "parser": "babel-eslint",
      "ecmaVersion": 2020,
      "sourceType": "module"
    },
    "rules": {
      "indent": ["error", 4, { "SwitchCase": 1 }],
      "semi": ["error", "never"],
      "quotes": ["error", "single"],
      "comma-dangle": ["error", "never"],
      "no-var": "error",
      "prefer-const": "error",
      "vue/html-indent": ["error", 4],
      "vue/max-attributes-per-line": ["error", {
        "singleline": 1,
        "multiline": 1
      }],
      "vue/component-name-in-template-casing": ["error", "kebab-case"],
      "vue/require-default-prop": "error",
      "vue/require-prop-types": "error"
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}